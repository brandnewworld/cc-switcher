# 私有凭证模版 — 复制到 $CC_SWITCHER_CRED_PATH/.env-<name>（默认 ~/.config/cc-switcher/）
# 文件名与 settings-<name>.json 对应，例如:
#   settings-deepseek.json   →  ~/.config/cc-switcher/.env-deepseek
#   settings-stepfun-api.json → ~/.config/cc-switcher/.env-stepfun-api
#
# 可设置 CC_SWITCHER_CRED_PATH 覆盖默认路径

# 供应商大多使用以下两者之一:
# export ANTHROPIC_API_KEY="sk-xxxxxxxx"
# export ANTHROPIC_AUTH_TOKEN="your-token-here"
